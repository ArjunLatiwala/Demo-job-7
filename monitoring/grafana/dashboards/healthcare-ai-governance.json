      "fieldConfig": {"defaults": {}, "overrides": []}
    },
    {
      "type": "stat",
      "title": "Platform SLO (Controlled)",
      "gridPos": {"h": 4, "w": 4, "x": 0, "y": 3},
      "targets": [{"expr": "avg(system_health) * 0.9998", "legendFormat": "SLO"}],
      "fieldConfig": {"defaults": {"unit": "percentunit", "decimals": 2, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "red", "value": 0}, {"color": "orange", "value": 0.95}, {"color": "green", "value": 0.99}]}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area", "justifyMode": "center", "textMode": "auto"}
    },
    {
      "type": "stat",
      "title": "Governed Requests / 5m",
      "gridPos": {"h": 4, "w": 4, "x": 4, "y": 3},
      "targets": [{"expr": "sum(increase(agent_requests_total[5m]))", "legendFormat": "governed requests"}],
      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "continuous-BlPu"}}, "overrides": []},
      "options": {"reduceOptions": {"calcs": ["lastNotNull"]}, "colorMode": "background", "graphMode": "area"}
    },
    {
      "type": "stat",
