      "fieldConfig": {"defaults": {"decimals": 0, "color": {"mode": "thresholds"}, "thresholds": {"steps": [{"color": "green", "value": 0}, {"color": "green", "value": 1}, {"color": "yellow", "value": 10}]}}, "overrides": []},
